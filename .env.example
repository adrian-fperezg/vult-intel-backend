# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"


# APP_URL: The Railway/backend server URL (used for tracking pixels and click-tracking links).
# MUST point to the backend API host, NOT the frontend.
APP_URL="https://your-backend.up.railway.app"

# FRONTEND_URL: The public-facing website URL (used to generate unsubscribe links in email footers).
# MUST point to the frontend host where /unsubscribe is served (e.g. Firebase Hosting).
# Without this, unsubscribe links will 404 because they'll point to the Railway API.
FRONTEND_URL="https://vultintel.com"

# Firebase Configuration
VITE_FIREBASE_API_KEY="YOUR_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID="YOUR_MEASUREMENT_ID"

# Hunter API System Fallback Key (Optional)
HUNTER_API_KEY_MASTER="YOUR_HUNTER_API_KEY"

# Logging Configuration
LOG_LEVEL="info"

# GCP Pub/Sub Configuration (Gmail Webhooks)
GCP_PROJECT_ID="YOUR_GCP_PROJECT_ID"
GCP_PUBSUB_TOPIC="gmail-notifications"
WEBHOOK_SECRET="YOUR_RANDOM_WEBHOOK_SECRET"
